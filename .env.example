# Copy to .env and fill in to turn each integration from SIMULATED to LIVE.
# Leave a section blank to keep that part in clearly-labeled simulation mode.

PORT=5173

# --- Step 3: Agent decision LLM (OpenAI-compatible Chat Completions) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Step 1: Casper x402 Facilitator (CSPR.cloud) ---
# Default facilitator is CSPR.cloud. Buildathon teams get sponsored access.
CASPER_X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
# CAIP-2 network id: casper:casper-test (testnet) or casper:casper (mainnet).
X402_NETWORK=casper:casper-test
# CSPR.cloud access token (UUID) from https://console.cspr.build (also used for the node RPC auth).
CSPR_CLOUD_ACCESS_KEY=
# CEP-18 token contract package hash used as the payment asset.
X402_ASSET=
# Payee public key hex (receives the CEP-18 micropayment).
X402_PAY_TO=
X402_TIMEOUT_SECONDS=900
# EIP-712 domain fields, must match the on-chain CEP-18 token.
X402_ASSET_NAME=Cep18x402
X402_ASSET_VERSION=1
X402_ASSET_DECIMALS=2
X402_ASSET_SYMBOL=CSPR

# --- Step 2: Casper Testnet settlement deploy (casper-js-sdk v5) ---
CASPER_NODE_RPC_URL=
CASPER_CHAIN_NAME=casper-test
# Provide the PEM contents inline OR a path to the secret key file.
CASPER_SECRET_KEY_PEM=
CASPER_SECRET_KEY_PATH=
# Deployed AgentPay Router settlement contract hash (hex, no "hash-" prefix).
CASPER_ROUTER_CONTRACT_HASH=
CASPER_SETTLEMENT_PAYMENT_MOTES=2500000000

# Set to 1 to make missing config throw instead of simulating.
AGENTPAY_STRICT=0
